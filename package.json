{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "import-downloads",
  "title": "Import Downloads",
  "description": "Move the most recently downloaded batch of files into the selected Finder folder.",
  "icon": "icon.png",
  "author": "Fredrik-psd",
  "license": "MIT",
  "platforms": [
    "macOS"
  ],
  "categories": [
    "Productivity"
  ],
  "commands": [
    {
      "name": "import",
      "title": "Import Downloads",
      "description": "Move the latest downloaded batch into the selected Finder folder",
      "mode": "no-view",
      "keywords": [
        "finder",
        "downloads",
        "import",
        "move"
      ]
    }
  ],
  "dependencies": {
    "@raycast/api": "1.104.12"
  },
  "devDependencies": {
    "@raycast/eslint-config": "2.1.1",
    "@types/node": "25.6.0",
    "eslint": "10.2.1",
    "prettier": "3.8.3",
    "typescript": "5.9.3"
  },
  "scripts": {
    "dev": "ray develop",
    "build": "ray build -e dist",
    "lint": "ray lint",
    "fix-lint": "ray lint --fix",
    "publish": "npx @raycast/api@latest publish"
  }
}
